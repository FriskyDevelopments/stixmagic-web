{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@stixmagic/ui": ["packages/ui/src/index.ts"],
      "@stixmagic/types": ["packages/types/src/index.ts"],
      "@stixmagic/config": ["packages/config/src/index.ts"]
    }
  }
}
