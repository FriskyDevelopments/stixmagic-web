NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
BOT_PORT=4100
STICKER_ENGINE_PORT=4200
TRIGGER_ENGINE_PORT=4300
POSTGRES_URL=postgres://stixmagic:stixmagic@localhost:5432/stixmagic
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sticker-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
TELEGRAM_BOT_TOKEN=replace_me
API_BASE_URL=http://localhost:4000

# Web app: point the dashboard at your backend API.
# When unset, the dashboard uses built-in mock data so the UI is browsable without a backend.
NEXT_PUBLIC_API_URL=http://localhost:4000

# The Telegram username of the Stix Magic bot (without @).
# Shown on the "Add bot to group" CTA on the Groups page.
NEXT_PUBLIC_BOT_USERNAME=StixMagicBot
